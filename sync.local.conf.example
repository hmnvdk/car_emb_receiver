# Скопируйте этот файл:  cp sync.local.conf.example sync.local.conf
# Файл sync.local.conf в git не попадает — там можно держать URL приватного репо.

# --- Аутентификация GitHub (обязательно выбрать один способ) ---
#
# 1) HTTPS — пароль от аккаунта НЕ подходит. Нужен Personal Access Token (Classic):
#    GitHub → Settings → Developer settings → Personal access tokens → Generate new (classic),
#    scope: repo. При git push логин: ваш логин, пароль: вставьте токен.
#    Чтобы не вводить каждый раз:  git config --global credential.helper store
#    (один раз введёте логин+токен — сохранится в ~/.git-credentials; не делайте на чужом ПК).
#
# 2) SSH — удобнее для постоянной работы (ключ, без токена в буфере):
#    ssh-keygen -t ed25519 -C "email"   затем публичный ключ добавить в GitHub → SSH keys.
#    REMOTE_URL ниже заменить на SSH-формат:
#    REMOTE_URL="git@github.com:hmnvdk/car_emb_receiver.git"

# HTTPS: https://github.com/ЛОГИН/РЕПО.git
# SSH:   git@github.com:ЛОГИН/РЕПО.git
REMOTE_URL="https://github.com/ВАШ_ЛОГИН/ВАШ_РЕПО.git"

# Ветка по умолчанию (должна совпадать с веткой на GitHub; у пустого репо ветки ещё нет — сначала push)
BRANCH="main"
