# Политика репозитория: в origin только README.md и каталог source/
# (этот файл нужен, чтобы не коммитить venv и кэши под source/)

*
!README.md
!.gitignore
!source/
!source/**/*

# Не коммитить окружение и мусор под source/
source/venv/
source/.venv/
source/**/__pycache__/
**/*.py[cod]
**/$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/

# Локальные скрипты и секреты в корне (рядом с репо), не в git
sync.sh
sync.local.conf
sync.local.conf.example
sync.secrets
sync.secrets.example
.git-credentials-local

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
